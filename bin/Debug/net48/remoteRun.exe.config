<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <!--
      방법 1) 환경 변수 EZRESOURCE_CONN, DSOM_CONN 사용 (권장)
      방법 2) connectionString에 DPAPI 암호화 값 사용 (encrypt-conn 옵션으로 생성)
      방법 3) Windows 인증: Integrated Security=true (uid/pwd 불필요)
    -->
    <add name="ezResource" connectionString="server=152.149.148.197;database=ezResource;uid=gwuser;pwd=ezflow2000;" providerName="System.Data.SqlClient" />
    <add name="DSOM" connectionString="server=152.149.148.197;database=DSOM;uid=gwuser;pwd=ezflow2000;" providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <!-- AES 키는 환경 변수 REMOTERUN_AES_KEY 사용을 권장합니다 -->
    <add key="REMOTERUN_AES_KEY" value="tdcvad123#" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>